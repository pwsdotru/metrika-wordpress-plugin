{
    "name": "pwsdotru/metrika-wordpress-plugin",
    "description": "Metrika plugin for Wordpress",
    "license": "GPL-3.0-or-later",
    "authors": [
      {
          "name": "Aleksandr Novikov",
          "email": "pwsdotru@gmail.com",
          "homepage": "https://github.com/pwsdotru"
      }
    ],
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "language": "msgfmt -o plugin_src/languages/metrika-ru_RU.mo plugin_src/languages/metrika-ru_RU.po",
        "style:check": "vendor/bin/phpcs",
        "style:fix": "vendor/bin/phpcbf",
        "git:prepush": [
            "@style:check"
        ]
    }
}
